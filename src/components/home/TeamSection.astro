---
import Container from '../common/Container.astro';
import SectionTitle from '../common/SectionTitle.astro';
import { teamCharacters } from '../../data/team';
---

<section class="overflow-hidden bg-[#1b1025] py-20">
  <Container>
    <SectionTitle title="Команда" />

    <div class="mt-12 grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-6">
      {teamCharacters.map((character) => (
        <div class="group rounded-2xl border border-white/10 bg-white/5 p-3 text-center transition hover:-translate-y-1">
          <div class="flex h-64 items-end justify-center overflow-hidden rounded-xl bg-[linear-gradient(180deg,#36203f_0%,#24142f_100%)]">
            <img
              src={character.image}
              alt={character.name}
              class="max-h-full w-auto object-contain transition group-hover:scale-[1.02]"
            />
          </div>
          <p class="mt-3 text-sm uppercase tracking-[0.15em] text-white/80">{character.name}</p>
        </div>
      ))}
    </div>
  </Container>
</section>