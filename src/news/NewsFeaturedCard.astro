---
interface Props {
    title: string;
    excerpt: string;
    image: string;
}

const { title, excerpt, image } = Astro.props;
---

<section class="py-10">
    <div class="mx-auto max-w-[1560px] px-4">
        <article class="overflow-hidden rounded-[38px] bg-transparent">
            <div
                class="grid overflow-hidden rounded-[38px] lg:grid-cols-[760px_minmax(0,1fr)]"
            >
                <div class="relative h-[320px] overflow-hidden lg:h-[740px]">
                    <img
                        src={image}
                        alt={title}
                        class="h-full w-full object-cover"
                    />
                </div>

                <div
                    class="flex h-full flex-col justify-between bg-[rgba(217,217,217,0.18)] px-6 py-6 backdrop-blur-[2px] md:px-8 md:py-8 lg:h-[740px] lg:px-10 lg:py-8"
                >
                    <div>
                        <h2
                            class="max-w-[560px] font-manrope text-3xl font-extrabold leading-tight text-white md:text-4xl lg:text-[58px] lg:leading-[76px]"
                        >
                            {title}
                        </h2>

                        <div
                            class="mt-6 max-w-[620px] overflow-hidden text-sm leading-6 text-white/95 md:text-base md:leading-7 lg:text-[25px] lg:leading-[34px]"
                        >
                            {excerpt}
                        </div>
                    </div>

                    <div class="mt-8 flex items-center justify-between gap-5">
                        <button
                            type="button"
                            class="flex h-[54px] w-[54px] items-center justify-center rounded-full bg-[rgba(179,179,179,0.2)] text-2xl text-white transition hover:bg-white/20"
                            aria-label="Назад"
                        >
                            ←
                        </button>

                        <button
                            type="button"
                            class="flex h-[54px] w-[54px] items-center justify-center rounded-full bg-[rgba(179,179,179,0.2)] text-2xl text-white transition hover:bg-white/20"
                            aria-label="Вперёд"
                        >
                            →
                        </button>
                    </div>
                </div>
            </div>
        </article>
    </div>
</section>
