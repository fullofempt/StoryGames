---
interface Props {
  title: string;
  image: string;
  description: string;
}
const { title, image, description } = Astro.props;
---

<article class="overflow-hidden font-handil rounded-[20px] border border-cyan-200/20 bg-white/5 shadow-xl backdrop-blur-sm">
  <div class="relative h-64 overflow-hidden md:h-80">
    <img src={image} alt={title} class="h-full w-full object-cover" />
    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,0,0,0.05)_0%,rgba(29,10,44,0.68)_100%)]"></div>
  </div>

  <div class="px-6 py-6 text-center">
    <h3 class="font-hand text-3xl text-white md:text-4xl">{title}</h3>
    <p class="mt-4 text-base leading-7 text-white/85 md:text-lg">{description}</p>
  </div>
</article>