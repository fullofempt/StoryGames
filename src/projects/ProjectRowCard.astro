---
interface Props {
    title: string;
    description: string;
    image: string;
    link: string;
    dev?: string;
    tgLink?: string;
    reverse?: boolean;
}

const {
    title,
    description,
    image,
    link,
    dev = "#",
    tgLink = "#",
    reverse = false,
} = Astro.props;
---

<article
    class="group drop-shadow-[0_9px_4px_rgba(0,0,0,0.25)] transition duration-500 hover:-translate-y-2"
>
    <div
        class:list={[
            "grid overflow-hidden rounded-[40px] border border-white/10 bg-white/5 backdrop-blur-sm transition duration-500 hover:border-[#7AF6EB]/50 hover:shadow-[0_0_40px_rgba(122,246,235,0.18)] lg:grid-cols-[650px_minmax(0,1fr)]",
            reverse && "lg:grid-cols-[minmax(0,1fr)_650px]",
        ]}
    >

        {!reverse ? (
            <>
                <!-- IMAGE -->

                <div
                    class="relative aspect-[16/8] overflow-hidden rounded-[40px] bg-black/20"
                >
                    <img
                        src={image}
                        alt={title}
                        class="h-full w-full object-cover transition duration-700 group-hover:scale-110"
                    />

                    <div
                        class="absolute inset-0 bg-gradient-to-t from-[#190925]/80 via-transparent"
                    ></div>
                </div>


                <!-- CONTENT -->

                <div class="flex flex-col justify-between px-8 py-6">

                    <div>
                        <h2
                            class="font-space text-3xl uppercase text-white transition duration-300 group-hover:text-[#7AF6EB] lg:text-[38px]"
                        >
                            {title}
                        </h2>


                        <p
                            class="mt-3 line-clamp-4 font-handil text-[18px] leading-7 text-white/85"
                        >
                            {description}
                        </p>
                    </div>


                    <!-- ACTIONS -->

                    <div class="mt-6 flex items-center gap-3">


                        <!-- STEAM -->

                        <a
                            href={link}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="group/icon flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-white/20 bg-white/10 transition duration-300 hover:-translate-y-1 hover:border-[#7AF6EB] hover:bg-[#7AF6EB]/20"
                        >
                            <img
                                src="/images/socials/steam.png"
                                alt="Steam"
                                class="h-6 w-6 transition duration-300 group-hover/icon:scale-110"
                            />
                        </a>


                        <!-- TELEGRAM -->

                        <a
                            href={tgLink}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="group/icon flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-white/20 bg-white/10 transition duration-300 hover:-translate-y-1 hover:border-[#7AF6EB] hover:bg-[#7AF6EB]/20"
                        >
                            <img
                                src="/images/socials/telegram.png"
                                alt="Telegram"
                                class="h-6 w-6 transition duration-300 group-hover/icon:scale-110"
                            />
                        </a>


                        <!-- DEVELOPERS -->

                        {/* <a
                            href={dev}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="group/icon flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-white/20 bg-white/10 transition duration-300 hover:-translate-y-1 hover:border-[#7AF6EB] hover:bg-[#7AF6EB]/20"
                        >
                            <img
                                src="/icons/developer.svg"
                                alt="Developers"
                                class="h-6 w-6 transition duration-300 group-hover/icon:scale-110"
                            />
                        </a> */}


                        <!-- GAME BUTTON -->

                        <a
                            href={link}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="ml-auto flex h-12 items-center justify-center rounded-full border border-[#7AF6EB]/50 bg-white/10 px-8 font-handil text-sm uppercase tracking-wider text-white transition duration-300 hover:-translate-y-1 hover:bg-[#7AF6EB]/20 hover:text-[#7AF6EB]"
                        >
                            Перейти к игре
                        </a>

                    </div>

                </div>
            </>
        ) : (

            <>
                <!-- CONTENT REVERSE -->

                <div class="flex flex-col justify-between px-8 py-6">

                    <div>
                        <h2
                            class="font-space text-3xl uppercase text-white transition duration-300 group-hover:text-[#7AF6EB] lg:text-[38px]"
                        >
                            {title}
                        </h2>


                        <p
                            class="mt-3 line-clamp-4 font-handil text-[18px] leading-7 text-white/85"
                        >
                            {description}
                        </p>
                    </div>


                    <div class="mt-6 flex items-center gap-3">


                        <a
                            href={link}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="group/icon flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-white/20 bg-white/10 transition hover:-translate-y-1 hover:border-[#7AF6EB] hover:bg-[#7AF6EB]/20"
                        >
                            <img
                                src="/images/socials/steam.png"
                                class="h-6 w-6 transition group-hover/icon:scale-110"
                            />
                        </a>


                        <a
                            href={tgLink}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="group/icon flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-white/20 bg-white/10 transition hover:-translate-y-1 hover:border-[#7AF6EB] hover:bg-[#7AF6EB]/20"
                        >
                            <img
                                src="/images/socials/telegram.png"
                                class="h-6 w-6 transition group-hover/icon:scale-110"
                            />
                        </a>


                        {/* <a
                            href={dev}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="group/icon flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-white/20 bg-white/10 transition hover:-translate-y-1 hover:border-[#7AF6EB] hover:bg-[#7AF6EB]/20"
                        >
                            <img
                                src="/icons/developer.svg"
                                class="h-6 w-6 transition group-hover/icon:scale-110"
                            />
                        </a> */}


                        <a
                            href={link}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="ml-auto flex h-12 items-center justify-center rounded-full border border-[#7AF6EB]/50 bg-white/10 px-8 font-handil text-sm uppercase tracking-wider text-white transition hover:-translate-y-1 hover:bg-[#7AF6EB]/20 hover:text-[#7AF6EB]"
                        >
                            Перейти к игре
                        </a>

                    </div>

                </div>


                <!-- IMAGE -->

                <div
                    class="relative aspect-[16/8] overflow-hidden rounded-[40px]"
                >
                    <img
                        src={image}
                        alt={title}
                        class="h-full w-full object-cover transition duration-700 group-hover:scale-110"
                    />
                </div>

            </>
        )}

    </div>
</article>