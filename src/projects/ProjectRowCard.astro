---
interface Props {
    title: string;
    description: string;
    image: string;
    reverse?: boolean;
}

const { title, description, image, reverse = false } = Astro.props;
---

<article class="drop-shadow-[0_9px_4px_rgba(0,0,0,0.25)]">
    <div
        class:list={[
            "grid overflow-hidden rounded-[40px] bg-[rgba(119,119,119,0.2)] lg:grid-cols-[842px_minmax(0,1fr)] lg:items-stretch",
            reverse && "lg:grid-cols-[minmax(0,1fr)_842px]",
        ]}
    >
        {
            !reverse ? (
                <>
                    <div class="relative h-[260px] overflow-hidden rounded-[40px] lg:h-[332px]">
                        <img
                            src={image}
                            alt={title}
                            class="h-full w-full scale-[1.04] object-cover"
                        />
                    </div>

                    <div class="flex h-[260px] flex-col justify-center overflow-hidden px-6 py-5 md:px-8 lg:h-[332px] lg:px-10 lg:py-6">
                        <h2 class="font-orbitron text-3xl uppercase text-white md:text-4xl lg:text-[50px] lg:leading-[50px]">
                            {title}
                        </h2>

                        <p class="mt-4 max-w-[772px] overflow-hidden text-base font-extrabold leading-7 text-white md:text-lg md:leading-8 lg:text-[20px] lg:leading-[21px]">
                            {description}
                        </p>
                    </div>
                </>
            ) : (
                <>
                    <div class="flex h-[260px] flex-col justify-center overflow-hidden px-6 py-5 md:px-8 lg:h-[332px] lg:px-10 lg:py-6">
                        <h2 class="font-orbitron text-3xl uppercase text-white md:text-4xl lg:text-[50px] lg:leading-[50px]">
                            {title}
                        </h2>

                        <p class="mt-4 max-w-[772px] overflow-hidden text-base font-extrabold leading-7 text-white md:text-lg md:leading-8 lg:text-[20px] lg:leading-[21px]">
                            {description}
                        </p>
                    </div>

                    <div class="relative h-[260px] overflow-hidden rounded-[40px] lg:h-[332px]">
                        <img
                            src={image}
                            alt={title}
                            class="h-full w-full scale-[1.04] object-cover"
                        />
                    </div>
                </>
            )
        }
    </div>
</article>
