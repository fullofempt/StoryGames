---
interface Props {
  title?: string;
}
const { title = 'StoryGames' } = Astro.props;
import '../styles/global.css';
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-[#140b20] text-white antialiased">
    <slot />
  </body>
</html>