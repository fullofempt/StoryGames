---
import FeaturedSlider from './FeaturedSlider.vue';

interface Props {
    title?: string;
    image?: string;
}

const {
    title,
    image
} = Astro.props;
---

<section class="relative py-16">

    <FeaturedSlider
        client:load
        initialTitle={title}
        initialImage={image}
    />

</section>