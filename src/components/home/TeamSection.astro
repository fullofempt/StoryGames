---
import Container from '../common/Container.astro';
import SectionTitle from '../common/SectionTitle.astro';
import TeamMemberCard from './TeamMemberCard.astro';
import { teamMembers } from '../../data/team';

const activeMember = teamMembers[0];
const previews = teamMembers.slice(1);
---

<section class="py-20">
  <Container>
    <div class="mb-10 flex items-center justify-center gap-4">
      <SectionTitle title="Команда" center={false} />

      <!-- <div class="hidden items-center gap-3 md:flex">
        <button
          type="button"
          class="flex h-[54px] w-[54px] items-center justify-center rounded-full bg-[rgba(81,81,81,0.2)] text-white transition hover:bg-white/20"
          aria-label="Предыдущий"
        >
          ←
        </button>

        <button
          type="button"
          class="flex h-[54px] w-[54px] items-center justify-center rounded-full bg-[rgba(81,81,81,0.2)] text-white transition hover:bg-white/20"
          aria-label="Следующий"
        >
          →
        </button>
      </div> -->
    </div>

    <TeamMemberCard {...activeMember} />

    {previews.length > 0 && (
      <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
        {previews.map((member) => (
          <div class="overflow-hidden rounded-2xl border border-cyan-400/30 bg-white/5 p-4 transition hover:-translate-y-1 hover:bg-white/10">
            <div class="flex items-center gap-4">
              <img
                src={member.image}
                alt={member.name}
                class="h-24 w-20 rounded-xl object-cover object-top"
              />

              <div>
                <h3 class="font-orbitron text-lg uppercase text-white">{member.name}</h3>
                <p class="mt-1 text-sm uppercase tracking-[0.12em] text-white/70">{member.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    )}
  </Container>
</section>