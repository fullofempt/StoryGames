---
interface Stat {
  label: string;
  value: number;
}

interface Props {
  name: string;
  role: string;
  image: string;
  stats: Stat[];
}

const { name, role, image, stats } = Astro.props;

const getBarClass = (index: number) => {
  const classes = [
    "bg-[#87FF1F]",
    "bg-[#FFDD1F]",
    "bg-[#FF8F1F]",
    "bg-[#FF4C1F]",
    "bg-[#FF1F1F]",
  ];

  return classes[index] ?? "bg-[#87FF1F]";
};
