<style>
  .stat-bar {
    transform-origin: left;

    animation: statAppear 0.6s ease forwards;
  }

  @keyframes statAppear {
    from {
      transform: scaleX(0);

      opacity: 0;
    }

    to {
      transform: scaleX(1);

      opacity: 1;
    }
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-6px);
    }
  }

  article:hover img {
    animation: float 3s ease-in-out infinite;
  }
</style>
