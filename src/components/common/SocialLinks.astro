---
interface Item {
  name: string;
  icon: string;
  href: string;
}
interface Props {
  items: Item[];
}
const { items } = Astro.props;
---

<div class="flex flex-wrap items-center justify-center gap-4">
  {items.map((item) => (
    <a
      href={item.href}
      aria-label={item.name}
      class="flex h-14 w-14 items-center justify-center rounded-full border border-white/20 bg-white/10 transition hover:scale-105 hover:bg-white/20"
    >
      <img src={item.icon} alt={item.name} class="h-8 w-8 object-contain" />
    </a>
  ))}
</div>