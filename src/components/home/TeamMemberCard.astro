---
interface Stat {
  label: string;
  value: number;
}

interface Props {
  name: string;
  role: string;
  image: string;
  stats: Stat[];
}

const { name, role, image, stats } = Astro.props;

const getBarClass = (index: number) => {
  const classes = [
    'bg-[#87FF1F]',
    'bg-[#FFDD1F]',
    'bg-[#FF8F1F]',
    'bg-[#FF4C1F]',
    'bg-[#FF1F1F]',
  ];
  return classes[index] ?? 'bg-[#87FF1F]';
};
---

<article class="relative overflow-hidden rounded-[20px] border-[3px] border-[#00A8CE] bg-[linear-gradient(180deg,rgba(25,9,37,0.78)_0%,rgba(91,40,67,0.78)_20%,rgba(154,71,96,0.78)_40%,rgba(91,40,67,0.78)_74%,rgba(25,9,37,0.78)_100%)] shadow-[0_12px_40px_rgba(0,0,0,0.35)]">
  <div class="grid grid-cols-1 lg:grid-cols-[360px_minmax(0,1fr)]">
    <div class="relative min-h-[360px] border-b border-cyan-400/30 lg:min-h-[560px] lg:border-r lg:border-b-0">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(0,168,206,0.18),transparent_70%)]"></div>
      <div class="absolute inset-3 rounded-[14px] border-2 border-[#00A8CE]/60 opacity-30 blur-[2px]"></div>
      <img
        src={image}
        alt={name}
        class="relative z-10 h-full w-full object-cover object-top"
      />
    </div>

    <div class="flex flex-col justify-between p-6 md:p-8 lg:p-10">
      <div>
        <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <div>
            <h3 class="font-orbitron text-3xl uppercase leading-tight text-white md:text-5xl lg:text-6xl">
              {name}
            </h3>
            <p class="mt-2 text-xl uppercase tracking-[0.2em] text-white/80 md:text-2xl">
              {role}
            </p>
          </div>
        </div>

        <div class="mt-8 space-y-6">
          {stats.map((stat) => (
            <div>
              <div class="mb-3 flex items-center justify-between gap-4">
                <span class="font-orbitron text-lg uppercase tracking-[0.08em] text-white md:text-2xl">
                  {stat.label}
                </span>
                <span class="text-sm text-white/60">{stat.value}/5</span>
              </div>

              <div class="flex flex-wrap gap-2">
                {Array.from({ length: 5 }).map((_, index) => (
                  <span
                    class:list={[
                      'h-[18px] w-[43px] rounded-[5px]',
                      index < stat.value ? getBarClass(index) : 'bg-white/10 border border-white/10',
                    ]}
                  />
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-8 border-t border-white/10 pt-6 text-sm leading-6 text-white/75 md:text-base">
        Участник команды StoryGames. Здесь можно разместить короткое описание роли, опыта,
        сильных сторон и вклада в проекты студии.
      </div>
    </div>
  </div>
</article>